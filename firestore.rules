rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper function: Check if user is admin ---
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Users Collection ---
    match /users/{userId} {
      // Users can read their own document
      allow read: if request.auth != null && request.auth.uid == userId;
      // Users doc is created automatically on first login
      allow create: if request.auth != null && request.auth.uid == userId;
      // Admin can update/delete user docs
      allow update, delete: if isAdmin();
    }

    // --- Menu Collection ---
    match /menuItems/{itemId} {
      // Anyone authenticated can read the menu
      allow read: if request.auth != null;
      // Only admin can write (add, update, delete)
      allow write: if isAdmin();
    }

    // --- Orders Collection ---
    match /orders/{orderId} {
      // Customers can read their own orders, Admin can read all
      allow read: if request.auth != null && 
        (resource.data.userId == request.auth.uid || isAdmin());
      // Customers can create orders (for themselves), Admins can create anything (Walk-ins)
      allow create: if request.auth != null && 
        (request.resource.data.userId == request.auth.uid || isAdmin());
      // Only admin can update order status
      allow update: if isAdmin();
      // No one can delete orders
      allow delete: if false;
    }
  }
}
